{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "",
    "Issuer": "EnglishExamApp",
    "Audience": "EnglishExamApp-Client",
    "ExpireMinutes": 1440
  },
  "Google": {
    "ClientId": ""
  },
  "AiScoringService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutMinutes": 30,
    "ReuseExistingSpeakingAnswerScores": true
  },
  "MinerU": {
    "BaseUrl": "http://localhost:8010",
    "Backend": "pipeline",
    "ParseMethod": "auto",
    "Languages": [
      "en"
    ],
    "EnableFormula": false,
    "EnableTable": true,
    "ReturnImages": false,
    "SaveDebugArtifacts": false,
    "DebugOutputDirectory": ".runtime/mineru-debug",
    "TimeoutMinutes": 10
  },
  "GeminiScoring": {
    "ApiKey": "",
    "BaseUrl": "https://generativelanguage.googleapis.com",
    "Model": "gemini-2.5-flash-lite",
    "FallbackModels": [
      "gemini-2.5-flash",
      "gemini-2.0-flash-lite"
    ],
    "FeedbackTranslationModel": "gemma-4-26b-a4b-it",
    "FeedbackTranslationFallbackModels": [
      "gemma-4-31b-it",
      "gemini-2.5-flash-lite"
    ],
    "Temperature": 0.1,
    "MaxImageBytes": 1500000,
    "MaxAttemptsPerModel": 3,
    "RetryBaseDelayMs": 1200
  },
  "GemmaExamGeneration": {
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta/openai/",
    "ApiKey": "",
    "Model": "gemini-3.1-flash-lite",
    "Temperature": 0.0,
    "MaxOutputTokens": 8192,
    "TimeoutMinutes": 10,
    "SendAuthorizationHeader": true
  },
  "GeminiCopilot": {
    "ApiKey": "",
    "BaseUrl": "https://generativelanguage.googleapis.com",
    "Model": "gemma-4-31b-it",
    "FallbackModels": [
      "gemma-4-26b-a4b-it",
      "gemini-3.1-flash-lite",
      "gemini-2.5-flash-lite"
    ],
    "WritingModel": "gemini-2.5-flash-lite",
    "WritingFallbackModels": [
      "gemini-2.5-flash",
      "gemini-2.0-flash-lite"
    ],
    "Temperature": 0.1,
    "MaxOutputTokens": 2048
  },
  "GeminiVisualExtraction": {
    "ApiKey": "",
    "BaseUrl": "https://generativelanguage.googleapis.com",
    "Model": "gemini-2.5-flash",
    "FallbackModels": [
      "gemini-2.5-flash-lite",
      "gemini-2.0-flash"
    ],
    "Temperature": 0.1,
    "MaxImageBytes": 4000000
  },
  "Vnpay": {
    "TmnCode": "",
    "HashSecret": "",
    "BaseUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "ReturnUrl": "http://localhost:5173/app/payment/vnpay-return",
    "IpnUrl": "http://localhost:5237/api/payments/vnpay/ipn",
    "Locale": "vn"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "FrontendUrl": "http://localhost:5173",
  "Email": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "FromEmail": "",
    "AppPassword": ""
  },
  "SeedAdmin": {
    "Password": ""
  }
}
