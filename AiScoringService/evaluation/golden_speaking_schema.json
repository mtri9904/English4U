{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Speaking evaluation metadata sample",
  "type": "object",
  "required": [
    "sample_id",
    "source_type",
    "dataset_level",
    "label_quality",
    "source_page_url",
    "claimed_overall_band",
    "has_criterion_breakdown"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "source_type": {
      "type": "string",
      "enum": ["youtube", "webpage_with_embedded_video", "local_audio", "other"]
    },
    "dataset_level": {
      "type": "string",
      "enum": ["bronze", "silver", "gold_candidate", "gold"]
    },
    "label_quality": {
      "type": "string",
      "enum": [
        "unknown",
        "youtube_claimed_band",
        "teacher_feedback",
        "examiner_style_report",
        "project_teacher_review",
        "official_examiner_score"
      ]
    },
    "source_page_url": {
      "type": "string"
    },
    "youtube_url": {
      "type": ["string", "null"]
    },
    "local_audio_path": {
      "type": ["string", "null"]
    },
    "speaker_label": {
      "type": ["string", "null"]
    },
    "candidate_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "claimed_overall_band": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 9,
      "multipleOf": 0.5
    },
    "claimed_criterion_scores": {
      "type": ["object", "null"],
      "properties": {
        "Fluency and Coherence": { "type": "number", "minimum": 0, "maximum": 9, "multipleOf": 0.5 },
        "Lexical Resource": { "type": "number", "minimum": 0, "maximum": 9, "multipleOf": 0.5 },
        "Grammatical Range and Accuracy": { "type": "number", "minimum": 0, "maximum": 9, "multipleOf": 0.5 },
        "Pronunciation": { "type": "number", "minimum": 0, "maximum": 9, "multipleOf": 0.5 }
      },
      "additionalProperties": false
    },
    "has_criterion_breakdown": {
      "type": "boolean"
    },
    "candidate_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["part_number", "start_seconds", "end_seconds"],
        "properties": {
          "part_number": { "type": "integer", "minimum": 1, "maximum": 3 },
          "prompt_type": { "type": ["string", "null"] },
          "prompt": { "type": ["string", "null"] },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 }
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "source_notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

